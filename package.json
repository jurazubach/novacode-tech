{
  "name": "novacode-tech-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Novacode Tech s.r.o. — company website (React + Vite, static, deployable to GitHub Pages).",
  "scripts": {
    "dev": "vite-react-ssg dev",
    "build": "tsc -b && vite-react-ssg build && node scripts/postbuild.mjs",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist -t true"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.1",
    "vite-react-ssg": "^0.9.1-beta.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
